{
    "name": "@htplus/k6-lib",
    "version": "0.1.0",
    "description": "Internal k6 performance testing library — REST + WebSocket, OpenAPI codegen, multi-auth.",
    "author": "batd@htplus.software",
    "license": "UNLICENSED",
    "engines": {
        "node": ">=18.0.0"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./reporter": {
            "types": "./dist/reporter/index.d.ts",
            "default": "./dist/reporter/index.js"
        }
    },
    "bin": {
        "k6-lib": "dist/cli/index.js"
    },
    "files": [
        "dist/",
        "README.md",
        "ARCHITECTURE.md"
    ],
    "scripts": {
        "clean": "rimraf dist workspaces/*/dist workspaces/*/reports workspaces/*/generated",
        "build": "tsc -p tsconfig.lib.json",
        "k6-lib": "node dist/cli/index.js"
    },
    "devDependencies": {
        "@babel/core": "^7.27.1",
        "@babel/preset-env": "^7.27.2",
        "@babel/preset-typescript": "^7.27.1",
        "@types/bcrypt": "^5.0.0",
        "@types/k6": "^1.1.1",
        "@types/node": "^24.0.12",
        "babel-loader": "^9.2.1",
        "rimraf": "^5.0.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "webpack": "^5.99.9",
        "webpack-cli": "^5.1.4",
        "webpack-merge": "^6.0.1",
        "webpack-node-externals": "^3.0.0"
    },
    "dependencies": {
        "dotenv": "^16.5.0",
        "js-yaml": "^4.1.1"
    }
}
